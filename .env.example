# ─────────────────────────────────────────────────
# AGENTE DE VOZ SOFÍA — Variables de Entorno
# Copia este archivo como .env y rellena los valores
# ─────────────────────────────────────────────────

# --- Google Gemini ---
# Obtener en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=tu_google_api_key_aqui

# --- LiveKit Cloud ---
# Obtener en: https://cloud.livekit.io → tu proyecto → Settings
LIVEKIT_URL=wss://tu-proyecto.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID del Troncal SIP Saliente (empieza con ST_)
# Configurar en: LiveKit Cloud → Telephony → SIP Trunks → Outbound
SIP_OUTBOUND_TRUNK_ID=ST_xxxxxxxxxxxxxxxx

# --- n8n Webhooks (URLs de producción, sin /test/) ---
N8N_SOFIA_CONFIRMAR=https://n8n.rapilinksas.co/webhook/sofia-confirmar
N8N_SOFIA_RECHAZO=https://n8n.rapilinksas.co/webhook/sofia-rechazo
N8N_SOFIA_REINTENTO=https://n8n.rapilinksas.co/webhook/sofia-reintento
N8N_SOFIA_ESCALAR=https://n8n.rapilinksas.co/webhook/sofia-escalar
